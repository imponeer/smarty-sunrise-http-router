{
    "name": "imponeer/smarty-sunrise-http-router",
    "description": "Smarty extensions to use with amazing router from sunrise-php",
    "type": "library",
    "require": {
        "imponeer/smarty-extensions-contracts": "^3.0",
        "php": "^8.1",
        "sunrise/http-router": "^3"
    },
    "license": "MIT",
    "minimum-stability": "beta",
    "config": {
        "preferred-install": {
            "phpstan/phpstan": "source"
        }
    },
    "repositories": [
        {
            "type": "git",
            "url": "https://github.com/phpstan/phpstan.git",
            "no-api": true,
            "canonical": false
        }
    ],
    "authors": [
        {
            "name": "Raimondas Rimkevičius (aka MekDrop)",
            "email": "github@mekdrop.name"
        }
    ],
    "autoload": {
        "psr-4": {
            "Imponeer\\Smarty\\Extensions\\SunriseHTTPRouter\\": "src/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^8 || ^9 || ^10",
        "phpstan/phpstan": "^2.1"
    },
    "scripts": {
        "test": "phpunit --testdox",
        "phpstan": "phpstan analyse -c phpstan.neon.dist"
    }
}
